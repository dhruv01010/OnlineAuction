<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Online Auction System</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <link rel="stylesheet" href="./css/index.css">
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f9f9f9;
      text-align: center;
      margin: 0;
    }

    header {
      background-color: #78a0e0;
      padding: 1.5rem;
      color: white;
      text-align: center;
    }

    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      background-color: #333;
      color: white;
      border-radius: 10px;
      max-width: 1350px;
      margin: 0 auto;
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .user-info span {
      font-weight: bold;
    }

    .logout-btn {
      background-color: #6b98e0;
      color: white;
      padding: 6px 16px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      transition: background-color 0.3s ease;
    }

    .logout-btn:hover {
      background-color: #5a86cc;
    }
  </style>
</head>

<body>
  <header>
    <h1>Online Auction</h1>
    <nav>
      <div class="section-1">
        {{#if user}}
        <a href="/home">Home</a>
        <a href="/auctions">Auctions</a>
        {{/if}}
      </div>
      <div class="section-2 user-info">
        {{#if user}}
        <span>Welcome, {{user.name}}</span>
        <form action="/logout" method="POST">
          <button class="logout-btn">Logout</button>
        </form>
        {{else}}
        <a href="/login">Login</a>
        <a href="/register">Signup</a>
        {{/if}}
      </div>
    </nav>
  </header>

  <main>
    <section class="hero-section">
      <h2>Welcome to the Ultimate Online Auction Experience</h2>
      <p>Bid in real-time, win exclusive items, and enjoy secure transactions.</p>
      {{!-- <button class="explore-btn">Explore Auctions</button> --}}
    </section>

    <section class="features-section">
      <div class="feature">
        <img src="https://source.unsplash.com/featured/?auction" alt="Live Auction">
        <h3>Live Auctions</h3>
        <p>Experience the thrill of real-time bidding and secure your favorite items.</p>
      </div>
      <div class="feature">
        <img src="https://source.unsplash.com/featured/?exclusive-items" alt="Exclusive Items">
        <h3>Exclusive Items</h3>
        <p>Browse rare and exclusive products available only on our platform.</p>
      </div>
    </section>
  </main>

  <footer class="footer-section">
    <p>&copy; 2025 Online Auction. All rights reserved.</p>
  </footer>

  {{!-- <script>
    {{!-- document.querySelector('.explore-btn').addEventListener('click', () => {
      window.location.href = '/auctions'; --}}
    });
  </script> --}}
</body>

</html>
