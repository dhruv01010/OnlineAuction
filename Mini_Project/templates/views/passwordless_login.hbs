<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login Without Password</title>
  <link rel="stylesheet" href="./css/login.css">
</head>
<body>
  <div class="login-container">
    <h1>Passwordless Login</h1>
    <form action="/passwordless_login" method="post" id="passwordlessForm">
      <div class="form-group">
        <label for="email">Enter your email to receive a login code</label>
        <input type="email" id="email" name="email" placeholder="Email Address" required>
      </div>
      <button type="submit" class="btn">Send Login Code</button>
    </form>
  </div>
  <script src="passwordless_login.js"></script>
</body>
</html>